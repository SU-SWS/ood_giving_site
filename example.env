# Example ENV File
#

# REQUIRED ENVIRONMENT VARS.
# ------------------------------------------------------------------------------
VAULT_SECRET_ID='YOU NEED TO CHANGE THIS'
VAULT_ROLE_ID='YOU NEED TO CHANGE THIS'

# OPTIONAL ENVIRONMENT VARS.
# ------------------------------------------------------------------------------
# VAULT_OVERWRITE=true

# VAULT ENVIRONMENT VARIABLES.
# ------------------------------------------------------------------------------
# After you copy this file over to .env run npm run vault to load the rest of
# the environment variables from vault. After that you can edit and ajust them
# as you need and restore them again at any time.

# OPTIONAL SEARCH/WEBHOOK OVERRIDES.
# ------------------------------------------------------------------------------
# Storyblok webhook signing secret (required for netlify/functions/storyblok-webhook.mts)
# STORYBLOK_WEBHOOK_SECRET='set-me'

# Algolia admin key used by webhook indexing function
# ALGOLIA_ADMIN_KEY='set-me'

# Optional index name overrides
# ALGOLIA_INDEX_NAME='Giving To Stanford (ISR)'
# ALGOLIA_SUGGESTIONS_INDEX_NAME='g2s_isr_query_suggestions'
# NEXT_PUBLIC_ALGOLIA_INDEX_NAME='Giving To Stanford (ISR)'
# NEXT_PUBLIC_ALGOLIA_SUGGESTIONS_INDEX_NAME='g2s_isr_query_suggestions'
#
